# Copy to .env — never commit real keys.

# Required
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
RELAYER_PRIVATE_KEY=0x

# Server
PORT=3001
MONGODB_URI=mongodb://localhost:27017/updown
CHAIN_ID=42161

# Contracts (dev defaults in config.ts; override for prod)
FACTORY_ADDRESS=0x05b1fd504583B81bd14c368d59E8c3e354b6C1dc
USDT_ADDRESS=0xCa4f77A38d8552Dd1D5E44e890173921B67725F4
AUTOCYCLER_ADDRESS=

# Off-chain balance wallet that receives platform fee from fills (defaults to relayer if unset)
FEE_TREASURY_ADDRESS=

# Optional: require this header value for POST /markets/:address/claim (else relayer must sign message)
CLAIM_ADMIN_API_KEY=

# Fees (basis points)
PLATFORM_FEE_BPS=70
MAKER_FEE_BPS=80

# Intervals (ms)
MATCHING_INTERVAL_MS=100
SETTLEMENT_BATCH_INTERVAL_MS=30000
MARKET_SYNC_INTERVAL_MS=15000
DEPOSIT_CONFIRMATIONS=3

# Proxied price history (chart)
SPEED_MARKET_API_BASE_URL=https://rain-speed-markets-dev-api.quecko.org
